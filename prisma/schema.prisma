generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String    @id @default(cuid())
  supabaseAuthId String?   @unique
  lineUserId     String?   @unique
  username       String?   @unique
  password       String?
  role           String    // "admin", "user", "technician", "engineer"
  fullname       String
  profilePicture String?
  dept           String?
  line           String?
  contact        String?
  status         String    @default("active")
  isChief        Boolean   @default(false)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  repairJobsRequested RepairJob[] @relation("Requester")
  repairJobsAssigned  RepairJob[] @relation("Technician")
  repairJobsQc        RepairJob[] @relation("QcBy")

  pmJobsDone          PmJob[] @relation("PmTechnician")
  pmJobsApproved      PmJob[] @relation("PmApprover")
}

model RepairJob {
  id           String    @id @default(cuid())
  jobId        String    @unique // e.g., REP-YYYYMMDD-HHmmss
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  requesterId  String
  requester    User      @relation("Requester", fields: [requesterId], references: [id])
  dept         String?
  machine      String?
  side         String?   
  opType       String?   
  detail       String?   
  imgBefore    String?
  imgBefore2   String?
  imgBefore3   String?
  imgAfter     String?
  status       String    @default("รอซ่อม") 
  
  technicianId String?
  technician   User?     @relation("Technician", fields: [technicianId], references: [id])
  doneDate     DateTime?
  planStopDate DateTime?
  eta          String?
  pendingReason String?
  rejectReason  String?
  note         String?

  qcResult     String?
  qcById       String?
  qcBy         User?     @relation("QcBy", fields: [qcById], references: [id])
  qcNote       String?
  qcDate       DateTime?

  acceptDate   DateTime?
  slaScore     Int?
}

model Machine {
  id           String    @id @default(cuid())
  name         String    @unique
  dept         String?
  status       String    @default("active")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model PmTemplate {
  id           String    @id @default(cuid())
  name         String    @unique
  machineType  String?   // e.g. "FLF", "Generic"
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  items        PmChecklistItem[]
  pmJobs       PmJob[]
}

model PmChecklistItem {
  id           String      @id @default(cuid())
  templateId   String
  template     PmTemplate  @relation(fields: [templateId], references: [id], onDelete: Cascade)
  taskName     String
  orderIndex   Int         @default(0)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  results      PmJobResult[]
}

model PmJob {
  id              String    @id @default(cuid())
  pmCode          String    @unique // e.g. PM-YYYYMMDD-HHmmss
  templateId      String
  template        PmTemplate @relation(fields: [templateId], references: [id])
  machine         String
  pmDate          DateTime
  shift           String?
  productionLine  String?
  technicianId    String
  technician      User      @relation("PmTechnician", fields: [technicianId], references: [id])
  approverId      String?
  approver        User?     @relation("PmApprover", fields: [approverId], references: [id])
  
  runningHours    Int?
  partsReplaced   String?
  overallCondition String   // "pass", "warn", "fail"
  workDone        String?
  remarks         String?
  nextPmDate      DateTime?
  
  status          String    @default("done")
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  results         PmJobResult[]
}

model PmJobResult {
  id            String    @id @default(cuid())
  pmJobId       String
  pmJob         PmJob     @relation(fields: [pmJobId], references: [id], onDelete: Cascade)
  checklistItemId String
  checklistItem PmChecklistItem @relation(fields: [checklistItemId], references: [id])
  
  result        String    // "pass", "fail", "n/a", etc.
  note          String?

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}
